rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() <= 100 &&
             data.mobileNumber is string && data.mobileNumber.size() <= 20 &&
             data.address is string && data.address.size() <= 500 &&
             data.status in ['Pending', 'Confirmed', 'Processing', 'Delivered', 'Cancelled'];
    }

    function isValidReview(data) {
      return data.productId is string && data.productId.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.rating is number &&
             data.comment is string && data.comment.size() <= 2000;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // For demo/initial setup. Ideally restricted to Admin.
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    match /reviews/{reviewId} {
      allow read, create, update, delete: if true;
    }

    match /orders/{orderId} {
      allow read, create, update, delete: if true;
    }

    match /visitor_sessions/{sessionId} {
      allow read, create, update, delete: if true;
    }
  }
}
